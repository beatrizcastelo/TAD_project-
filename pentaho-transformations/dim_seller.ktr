  <step>
    <name>calc region</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var region;

if (state == "SP" || state == "RJ" || state == "MG" || state == "ES") {
    region = "Sudeste";
} else if (state == "PR" || state == "SC" || state == "RS") {
    region = "Sul";
} else if (state == "BA" || state == "SE" || state == "AL" || state == "PE" || 
           state == "PB" || state == "RN" || state == "CE" || state == "PI" || 
           state == "MA") {
    region = "Nordeste";
} else if (state == "GO" || state == "MT" || state == "MS" || state == "DF") {
    region = "Centro-Oeste";
} else {
    region = "Norte";
}

var lat = parseFloat("" + latitude);
var lng = parseFloat("" + longitude);</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>region</name>
        <rename>region</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
