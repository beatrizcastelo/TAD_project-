    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var dt = "" + full_date;
var date_year   = parseInt(dt.substr(0, 4), 10);
var date_month  = parseInt(dt.substr(5, 2), 10);
var date_day    = parseInt(dt.substr(8, 2), 10);
var quarter     = Math.ceil(date_month / 3);
var day_of_week = new Date(date_year, date_month-1, date_day).getDay() + 1;
var hour        = parseInt(dt.substr(11, 2), 10);</jsScript_script>
      </jsScript>
    </jsScripts>
