  <step>
    <name>calc delivery fields</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// 1. Inicializar métricas
var actual_delivery_days = 0;
var delay_days = 0;
var is_late_delivery = 0;

// 2. Cálculo usando "full_date" (o nome novo que deste no lookup)
if (order_delivered_customer_date != null &amp;&amp; full_date != null) {
    // Converter para objetos de data caso venham como String
    var d1 = new Date(order_delivered_customer_date);
    var d2 = new Date(full_date);
    
    var timeDiff = d1.getTime() - d2.getTime();
    actual_delivery_days = Math.floor(timeDiff / (1000 * 3600 * 24));
}

// 3. Cálculo do atraso
if (order_delivered_customer_date != null &amp;&amp; order_estimated_delivery_date != null) {
    var d_deliv = new Date(order_delivered_customer_date);
    var d_est = new Date(order_estimated_delivery_date);
    
    var delayDiff = d_deliv.getTime() - d_est.getTime();
    delay_days = Math.floor(delayDiff / (1000 * 3600 * 24));
    
    is_late_delivery = (delay_days > 0) ? 1 : 0;
}

// 4. Limpeza final (Anti-NaN)
if (isNaN(actual_delivery_days)) actual_delivery_days = 0;
if (isNaN(delay_days)) delay_days = 0;</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>actual_delivery_days</name>
        <rename>actual_delivery_days</rename>
        <type>Number</type>
        <length>16</length>
        <precision>2</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>delay_days</name>
        <rename>delay_days</rename>
        <type>Number</type>
        <length>16</length>
        <precision>2</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>is_late_delivery</name>
        <rename>is_late_delivery</rename>
        <type>Number</type>
        <length>16</length>
        <precision>2</precision>
        <replace>N</replace>
      </field>
    </fields>
