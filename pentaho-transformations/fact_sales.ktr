    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
var fd_year = 0; var fd_month = 0; var fd_day = 0; var fd_hour = 0;
if (full_date != null) {
  var s = "" + full_date;
  if (s.length >= 13) {
    fd_year  = parseInt(s.substring(0,4), 10);
    fd_month = parseInt(s.substring(5,7), 10);
    fd_day   = parseInt(s.substring(8,10), 10);
    fd_hour  = parseInt(s.substring(11,13), 10);
  }
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>fd_year</name>
